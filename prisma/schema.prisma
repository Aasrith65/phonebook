generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id           String   @id @default(cuid())
  name         String
  organization String?
  category     String   @default("Others")
  phoneNumber  String
  designation  String?
  address      String?
  comments     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
